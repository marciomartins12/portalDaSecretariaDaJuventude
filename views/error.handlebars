<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      <h1 class="pageHero__title">{{title}}</h1>
      <p class="pageHero__subtitle">{{message}}</p>
      <div class="pageHero__actions">
        <a class="btn btn--primary" href="/">Voltar ao início</a>
      </div>
    </div>
    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Tente novamente em instantes.
      </div>
    </div>
  </div>
</section>


<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Peri Mirim (MA)"}}
      <h1 class="pageHero__title">Peri Mirim (MA)</h1>
      <p class="pageHero__subtitle">Informações e serviços da Secretaria da Juventude de Peri Mirim.</p>
    </div>

    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Confira eventos, editais e notícias voltadas à juventude de Peri Mirim.
      </div>
      <div class="pageHero__actions">
        <a class="btn btn--soft" href="/eventos">Eventos</a>
        <a class="btn btn--ghost" href="/noticias">Notícias</a>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid2">
      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="spark"></div>
        <h2 class="card__title">O que é Peri Mirim</h2>
        <p class="card__desc">
          Peri Mirim é um município do estado do Maranhão (MA), Brasil. Esta página reúne informações e acessos rápidos a
          serviços, notícias e oportunidades da Secretaria Municipal da Juventude de Peri Mirim.
        </p>
      </article>

      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="target"></div>
        <h2 class="card__title">Participar</h2>
        <p class="card__desc">Acompanhe os eventos em andamento e os comunicados oficiais.</p>
        <div class="cardActions">
          <a class="btn btn--primary" href="/eventos">Eventos</a>
          <a class="btn btn--ghost" href="/editais">Editais</a>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid2">
      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="users"></div>
        <h2 class="card__title">Serviços para a Juventude</h2>
        <p class="card__desc">
          A Secretaria da Juventude de Peri Mirim (MA) promove ações, formações e eventos voltados ao desenvolvimento
          dos jovens no município, fortalecendo oportunidades e participação cidadã.
        </p>
        <ul class="kv" style="margin-top:10px">
          <li class="kv__row"><div class="kv__k">Eventos</div><div class="kv__v"><a href="/eventos">Acompanhar eventos</a></div></li>
          <li class="kv__row"><div class="kv__k">Notícias</div><div class="kv__v"><a href="/noticias">Acompanhar novidades</a></div></li>
          <li class="kv__row"><div class="kv__k">Contato</div><div class="kv__v"><a href="{{site.phoneHref}}">{{site.phone}}</a> • {{site.email}}</div></li>
        </ul>
      </article>

      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="bolt"></div>
        <h2 class="card__title">Eventos em Peri Mirim</h2>
        <p class="card__desc">Participe das ações em Peri Mirim (MA):</p>
        <ul class="kv" style="margin-top:10px">
          <li class="kv__row"><div class="kv__k">Gincana</div><div class="kv__v"><a href="/gincana">{{gincana.title}}</a></div></li>
          <li class="kv__row"><div class="kv__k">Corrida</div><div class="kv__v"><a href="/eventos">{{corrida.title}}</a></div></li>
          <li class="kv__row"><div class="kv__k">Sorteio</div><div class="kv__v"><a href="/eventos">Sorteio para Piscicultores</a></div></li>
          <li class="kv__row"><div class="kv__k">Jogos</div><div class="kv__v"><a href="/eventos">Jogos Variados</a></div></li>
        </ul>
      </article>
    </div>
  </div>
</section>

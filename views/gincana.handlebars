<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Gincana"}}
      <h1 class="pageHero__title">Gincana</h1>
      <p class="pageHero__subtitle">{{gincana.title}}</p>
    </div>

    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Acompanhe as atualizações da gincana.
      </div>
      <div class="pageHero__actions">
        <a class="btn btn--soft" href="/editais/gincana/pdf">Ver edital</a>
        <a class="btn btn--ghost" href="/eventos">Ver eventos</a>
      </div>
    </div>
  </div>
</section>



<section class="gincanaSplash" style="--gincana-splash-image: url('/public/assets/fotoPrincipalDaGinacana.png?v={{assetVersion}}');"></section>
<section class="hero gincanaHeader">
  <div class="container">
    <div class="hero__grid">
      <div class="gincanaHeader__copy">
        {{> pageCrumb current="Gincana"}}
        <h1 class="hero__title">Gincana Celebra Peri Mirim</h1>
        <p class="hero__subtitle">A energia da vitória já começou: acompanhe o pódio da Gincana 2026, os destaques e os arquivos oficiais do evento.</p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="#podio">Ver pódio</a>
          <a class="btn btn--soft" href="/editais/gincana/pdf">Baixar edital</a>
          <a class="btn btn--ghost" href="#provas">Ver provas</a>
        </div>
      </div>

      <div class="hero__panel cardNeon neonBorder cardNeon--pulse hero__panel--victory">
        <div class="heroCard heroCard--victory">
          <div class="heroCard__top">
            <div class="heroCard__lead">
              <div class="heroCard__eyebrow heroCard__eyebrow--victory">Painel da Vitória</div>
              <div class="heroCard__title">{{#if podium.first}}{{podium.first.teamName}}{{else}}Equipe vencedora{{/if}}</div>
              <div class="heroCard__info">Campeã da Gincana 2026. Abaixo, o pódio oficial com o Top 3 — toque em uma posição para ver os integrantes.</div>
            </div>
            <div class="heroCard__trophy" aria-hidden="true">
              <span class="heroCard__trophyGlow"></span>
              <span class="heroCard__trophyIcon">🏆</span>
            </div>
          </div>

          <div class="heroCard__meta heroCard__meta--compact">
            <div class="metaPill metaPill--victory">
              <span class="i" aria-hidden="true">🏆</span>
              <span class="metaPill__text">{{#if podium.first}}{{podium.first.teamName}}{{else}}Aguardando campeã{{/if}}</span>
            </div>
            <div class="metaPill">
              <span class="i" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 21s7-4.4 7-11a7 7 0 1 0-14 0c0 6.6 7 11 7 11Z" stroke="currentColor" stroke-width="1.6"/>
                  <path d="M12 10.8a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4Z" fill="currentColor" opacity=".85"/>
                </svg>
              </span>
              <span class="metaPill__text">{{gincana.location}}</span>
            </div>
          </div>

          <div class="victoryPanel__strip">
            <p class="victoryPanel__stripText">Cada prova conta uma história — o pódio celebra quem brilhou em 2026.</p>
          </div>

          
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title" id="podio">Pódio da Gincana 2026</h2>
      <p class="section__desc">Clique em 1º, 2º ou 3º lugar para ver os integrantes da equipe vencedora.</p>
    </div>

    <div class="podium glass reveal">
      <div class="podium__head">
        <div class="podium__titleRow">
          <div class="podium__title">Pódio da Gincana 2026</div>
          <div class="podium__badge">🏆 Ranking Oficial</div>
        </div>
        <div class="podium__subtitle">Toque em uma equipe para abrir a lista de integrantes.</div>
      </div>
      <div class="podium__stage">
        <div class="podium__col podium__col--2">
          <div class="podium__stack">
            <button
              class="podium__card podium__block podium__blockButton"
              type="button"
              data-team-open
              data-team-title="{{#if podium.second}}2º lugar • {{podium.second.teamName}}{{else}}2º lugar{{/if}}"
              style="--team-color: #facc15;"
              {{#unless podium.second}}disabled{{/unless}}
            >
              <div class="podium__cardInner">
                <div class="podium__medalRow">
                  <span class="podium__medal" aria-hidden="true">🥈</span>
                  <span class="podium__rankLabel">2º lugar</span>
                </div>
                <div class="podium__name">{{#if podium.second}}{{podium.second.teamName}}{{else}}—{{/if}}</div>
                <div class="podium__ribbon">Vice-campeã</div>
              </div>
              <div class="teamMembersTpl" hidden data-team-members>
                {{#if podium.second}}
                  {{#each podium.second.members}}
                    <div class="teamMemberRow {{#if isCaptain}}teamMemberRow--captain{{/if}}">
                      <div class="teamMemberRow__index" aria-hidden="true">{{addOne @index}}</div>
                      <div class="teamMemberRow__main">
                        <div class="teamMemberRow__name">{{fullName}}</div>
                        <div class="teamMemberRow__roleText">{{role}}</div>
                      </div>
                      <div class="teamMemberRow__tag">{{#if isCaptain}}Capitão{{else}}Membro{{/if}}</div>
                    </div>
                  {{/each}}
                {{/if}}
              </div>
            </button>
            <div class="podium__plinth podium__plinth--2" aria-hidden="true"></div>
          </div>
        </div>
        <div class="podium__col podium__col--1">
          <div class="podium__stack">
            <button
              class="podium__card podium__block podium__blockButton"
              type="button"
              data-team-open
              data-team-title="{{#if podium.first}}1º lugar • {{podium.first.teamName}}{{else}}1º lugar{{/if}}"
              style="--team-color: #ef4444;"
              {{#unless podium.first}}disabled{{/unless}}
            >
              <div class="podium__cardInner">
                <div class="podium__crown" aria-hidden="true">👑</div>
                <div class="podium__medalRow">
                  <span class="podium__medal" aria-hidden="true">🥇</span>
                  <span class="podium__rankLabel">1º lugar</span>
                </div>
                <div class="podium__name">{{#if podium.first}}{{podium.first.teamName}}{{else}}—{{/if}}</div>
                <div class="podium__ribbon">Grande campeã</div>
              </div>
              <div class="teamMembersTpl" hidden data-team-members>
                {{#if podium.first}}
                  {{#each podium.first.members}}
                    <div class="teamMemberRow {{#if isCaptain}}teamMemberRow--captain{{/if}}">
                      <div class="teamMemberRow__index" aria-hidden="true">{{addOne @index}}</div>
                      <div class="teamMemberRow__main">
                        <div class="teamMemberRow__name">{{fullName}}</div>
                        <div class="teamMemberRow__roleText">{{role}}</div>
                      </div>
                      <div class="teamMemberRow__tag">{{#if isCaptain}}Capitão{{else}}Membro{{/if}}</div>
                    </div>
                  {{/each}}
                {{/if}}
              </div>
            </button>
            <div class="podium__plinth podium__plinth--1" aria-hidden="true"></div>
          </div>
        </div>
        <div class="podium__col podium__col--3">
          <div class="podium__stack">
            <button
              class="podium__card podium__block podium__blockButton"
              type="button"
              data-team-open
              data-team-title="{{#if podium.third}}3º lugar • {{podium.third.teamName}}{{else}}3º lugar{{/if}}"
              style="--team-color: #3b82f6;"
              {{#unless podium.third}}disabled{{/unless}}
            >
              <div class="podium__cardInner">
                <div class="podium__medalRow">
                  <span class="podium__medal" aria-hidden="true">🥉</span>
                  <span class="podium__rankLabel">3º lugar</span>
                </div>
                <div class="podium__name">{{#if podium.third}}{{podium.third.teamName}}{{else}}—{{/if}}</div>
                <div class="podium__ribbon">Top 3</div>
              </div>
              <div class="teamMembersTpl" hidden data-team-members>
                {{#if podium.third}}
                  {{#each podium.third.members}}
                    <div class="teamMemberRow {{#if isCaptain}}teamMemberRow--captain{{/if}}">
                      <div class="teamMemberRow__index" aria-hidden="true">{{addOne @index}}</div>
                      <div class="teamMemberRow__main">
                        <div class="teamMemberRow__name">{{fullName}}</div>
                        <div class="teamMemberRow__roleText">{{role}}</div>
                      </div>
                      <div class="teamMemberRow__tag">{{#if isCaptain}}Capitão{{else}}Membro{{/if}}</div>
                    </div>
                  {{/each}}
                {{/if}}
              </div>
            </button>
            <div class="podium__plinth podium__plinth--3" aria-hidden="true"></div>
          </div>
        </div>
      </div>
      <div class="podium__floor" aria-hidden="true"></div>
      <div class="podium__desc">Parabéns ao Top 3 da Gincana 2026.</div>
    </div>
  </div>
</section>

<div class="modal modal--team" id="teamMembersModal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="teamMembersModalTitle">
  <button class="modal__backdrop modal__backdrop--team" type="button" data-modal-close aria-label="Fechar"></button>
  <div class="modal__panel glass teamModalPanel">
    <div class="teamModalChrome" aria-hidden="true">
      <span class="teamModalChrome__handle"></span>
      <span class="teamModalChrome__glow"></span>
    </div>
    <div class="modal__head teamModalHead">
      <div class="teamModalHead__main">
        <p class="teamModalEyebrow" data-team-modal-rank></p>
        <h2 class="teamModalTitle" id="teamMembersModalTitle" data-team-modal-title>Integrantes</h2>
      </div>
      <button class="teamModalClose" type="button" data-modal-close aria-label="Fechar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="modal__body teamModalBody">
      <p class="teamModalHint">O capitão aparece em destaque na lista.</p>
      <div class="teamModalList" data-team-modal-list></div>
    </div>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title" id="provas">Provas</h2>
      <p class="section__desc">Baixe os PDFs das provas em ordem.</p>
    </div>

    {{#if provas.length}}
      <div class="provasList">
        {{#each provas}}
          <div class="provasItem glass reveal">
            <div class="provasItem__left">
              <div class="provasItem__num">{{addOne @index}}</div>
              <div class="provasItem__name">{{name}}</div>
            </div>
            <div class="provasItem__actions">
              <a class="btn btn--primary" href="{{href}}">Baixar PDF</a>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="alert glass reveal" role="status">
        <div class="alert__title">Sem provas disponíveis</div>
        <div class="alert__desc">Assim que os PDFs forem adicionados, eles aparecerão nesta lista.</div>
      </div>
    {{/if}}
  </div>
</section>

<section class="section section--highlight">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title" id="arquivos">Arquivos</h2>
      <p class="section__desc">Baixe o edital oficial.</p>
    </div>

    <div class="grid2">
      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="spark"></div>
        <h3 class="card__title">📄 Edital</h3>
        <p class="card__desc">Regras e orientações oficiais da gincana.</p>
        <div class="cardActions">
          <a class="btn btn--primary" href="/editais/gincana/pdf">Baixar edital (PDF)</a>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Página não encontrada"}}
      <h1 class="pageHero__title">Página não encontrada</h1>
      <p class="pageHero__subtitle">O link pode ter sido alterado ou não existe mais.</p>
      <div class="pageHero__actions">
        <a class="btn btn--primary" href="/">Voltar ao início</a>
        <a class="btn btn--ghost" href="/eventos">Eventos</a>
      </div>
    </div>
    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Se precisar, fale com a Secretaria para orientação.
      </div>
    </div>
  </div>
</section>

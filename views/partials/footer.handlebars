<footer class="footer">
  <div class="container footer__grid">
    <div>
      <div class="footer__title">{{site.departmentName}}</div>
      <div class="footer__muted">{{site.municipalityName}}</div>
      <div class="footer__muted">{{site.tagline}}</div>
      <div class="footer__muted">{{site.hours}}</div>
      <div class="footer__links" style="margin-top:10px">
        <a class="footer__link" href="/peri-mirim">Peri Mirim (MA)</a>
      </div>
    </div>

    <div>
      <div class="footer__subtitle">Contato</div>
      <div class="footer__links">
        {{#if site.phoneHref}}
          <a class="footer__link" href="{{site.phoneHref}}">
            <span class="i" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.5 10.5c1.6 3.2 2.8 4.4 6 6l2-2c.6-.6 1.4-.7 2.1-.4l2.6 1.1c.7.3 1.1 1.1.9 1.8-.4 1.3-1.6 2.3-3 2.3C10 19.7 4.3 14 4.3 6c0-1.4 1-2.6 2.3-3 .7-.2 1.5.2 1.8.9l1.1 2.6c.3.7.2 1.5-.4 2.1l-1.6 1.9z" stroke="currentColor" stroke-width="1.6" opacity=".9"/>
              </svg>
            </span>
            {{site.phone}}
          </a>
        {{/if}}

        <a class="footer__link" href="mailto:{{site.email}}">
          <span class="i" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Z" stroke="currentColor" stroke-width="1.6"/>
              <path d="M6.2 8.2 12 12.2l5.8-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" opacity=".9"/>
            </svg>
          </span>
          {{site.email}}
        </a>

        <a class="footer__link" href="{{site.instagramUrl}}" target="_blank" rel="noreferrer">
          <span class="i" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4Z" stroke="currentColor" stroke-width="1.6"/>
              <path d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" stroke="currentColor" stroke-width="1.6"/>
              <path d="M17.6 6.4h.01" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/>
            </svg>
          </span>
          {{site.instagramLabel}}
        </a>
        <div class="footer__muted footer__address">Endereço: {{site.address}}</div>
      </div>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {{year}} {{site.departmentName}}</span>
    <span class="footer__tag">Portal oficial • Jovem • Inspirador</span>
  </div>
</footer>

<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Editais"}}
      <div class="badge">
        <span class="badge__dot"></span>
        Documentos oficiais
      </div>
      <h1 class="pageHero__title">Editais</h1>
      <p class="pageHero__subtitle">Acesse os editais por evento.</p>
    </div>

    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Para participar, confira regras e prazos do evento escolhido.
      </div>
      <div class="pageHero__actions">
        <a class="btn btn--soft" href="/eventos">Eventos</a>
        <a class="btn btn--ghost" href="/">Voltar ao início</a>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid2">
      <article class="card glass reveal">
          <div class="card__icon" aria-hidden="true" data-icon="shield"></div>
          <h2 class="card__title editaltiotulomaior">Edital Gincana Celebra Peri Mirim</h2>
          <p class="card__desc">{{gincana.title}} • {{gincana.dateLabel}}</p>
          <div class="cardActions">
            <a class="btn btn--primary" href="/editais/gincana/pdf">Baixar Edital (PDF)</a>
            <a class="btn btn--ghost" href="/gincana">Acompanhar gincana</a>
          </div>
        </article>

    </div>
  </div>
</section>

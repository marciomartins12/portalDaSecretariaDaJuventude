<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Edital"}}
      <div class="badge">
        <span class="badge__dot"></span>
        Documento oficial
      </div>
      <h1 class="pageHero__title">Edital da Gincana</h1>
      <p class="pageHero__subtitle">{{gincana.title}} • {{gincana.dateLabel}}</p>
      <div class="pageHero__actions">
        <a class="btn btn--primary" href="/editais/gincana/pdf">Baixar Edital (PDF)</a>
        <a class="btn btn--ghost" href="/inscricoes/gincana">Fazer Inscrição</a>
      </div>
    </div>

    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Baixe o edital completo em PDF para ver regras, prazos e orientações oficiais.
      </div>
    </div>
  </div>
</section>

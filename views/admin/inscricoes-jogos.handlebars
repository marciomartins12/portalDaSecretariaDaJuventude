<div class="adminShell">
  {{> adminSidebar active="inscricoes"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Inscritos — Jogos Variados</div>
        <div class="adminTop__meta">{{total}} inscrição(ões)</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <a class="btn btn--primary" href="{{exportHref}}">Exportar DOCX</a>
        <a class="btn" href="/admin/inscricoes">Voltar</a>
      </div>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Filtros</div>
        </div>
        <div class="panel__body">
          <form class="form formFilters" method="get" action="/admin/inscricoes/jogos">
            <div class="field">
              <label class="label" for="q">Nome do participante</label>
              <input class="input" id="q" name="q" type="text" value="{{q}}" placeholder="Ex.: Maria Silva" />
            </div>
            <div class="field">
              <label class="label" for="sport">Esporte</label>
              <select class="input" id="sport" name="sport">
                <option value="">Todos</option>
                <option value="domino" {{#if (eq sport "domino")}}selected{{/if}}>Dominó</option>
                <option value="sinuca" {{#if (eq sport "sinuca")}}selected{{/if}}>Sinuca</option>
                <option value="travinho" {{#if (eq sport "travinho")}}selected{{/if}}>Travinho</option>
                <option value="videogame_bomba_patch" {{#if (eq sport "videogame_bomba_patch")}}selected{{/if}}>Videogame (Bomba Patch)</option>
                <option value="dama" {{#if (eq sport "dama")}}selected{{/if}}>Dama</option>
              </select>
            </div>
            <div class="actions">
              <button class="btn btn--primary" type="submit">Filtrar</button>
              <a class="btn" href="/admin/inscricoes/jogos">Limpar</a>
            </div>
          </form>
        </div>
      </div>
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Lista</div>
        </div>
        <div class="panel__body tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Data</th>
                <th>Nome</th>
                <th>Telefone</th>
                <th>CPF</th>
                <th>Esportes</th>
              </tr>
            </thead>
            <tbody>
              {{#each rows}}
                <tr>
                  <td class="muted">{{id}}</td>
                  <td class="muted">{{createdAt}}</td>
                  <td>{{fullName}}</td>
                  <td class="muted">{{phone}}</td>
                  <td class="muted">{{cpf}}</td>
                  <td class="muted">{{sports}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

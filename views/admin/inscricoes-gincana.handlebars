<div class="adminShell">
  {{> adminSidebar active="inscricoes"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Inscritos — Gincana</div>
        <div class="adminTop__meta">{{total}} equipe(s)</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <a class="btn btn--primary" href="{{exportHref}}">Exportar DOCX</a>
        <a class="btn" href="/admin/inscricoes">Voltar</a>
      </div>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Filtrar equipes</div>
        </div>
        <div class="panel__body">
          <form class="form formFilters" method="get" action="/admin/inscricoes/gincana">
            <div class="field">
              <label class="label" for="q">Nome da equipe</label>
              <input class="input" id="q" name="q" type="text" value="{{q}}" placeholder="Ex.: Piaba Ativa" />
            </div>
            <div class="actions">
              <button class="btn btn--primary" type="submit">Filtrar</button>
              <a class="btn" href="/admin/inscricoes/gincana">Limpar</a>
            </div>
          </form>
        </div>
      </div>

      {{#if error}}
        <div class="alert alert--error">{{error}}</div>
      {{/if}}
      {{#if success}}
        <div class="alert alert--success">{{success}}</div>
      {{/if}}
      {{#each teams}}
        <div class="panel" id="team-{{id}}">
          <div class="panel__head">
            <div class="panel__title">{{teamName}}</div>
            <div class="muted">Criado em {{createdAt}}</div>
          </div>
          <div class="panel__body">
            <div class="kvGrid">
              <div class="card">
                <div class="card__k">Equipe</div>
                <div class="kv">
                  <div class="kv__row"><div class="kv__k">Nome</div><div class="kv__v">{{teamName}}</div></div>
                  <div class="kv__row"><div class="kv__k">Bairro</div><div class="kv__v">{{neighborhood}}</div></div>
                  <div class="kv__row"><div class="kv__k">Participantes informados</div><div class="kv__v">{{participantsTotal}}</div></div>
                  <div class="kv__row"><div class="kv__k">Criado em</div><div class="kv__v">{{createdAt}}</div></div>
                </div>
              </div>

              <div class="card">
                <div class="card__k">Líder</div>
                <div class="kv">
                  <div class="kv__row"><div class="kv__k">Nome</div><div class="kv__v">{{captainName}}</div></div>
                  <div class="kv__row"><div class="kv__k">E-mail</div><div class="kv__v">{{captainEmail}}</div></div>
                  <div class="kv__row"><div class="kv__k">Telefone</div><div class="kv__v">{{captainPhone}}</div></div>
                  <div class="kv__row"><div class="kv__k">Nascimento</div><div class="kv__v">{{captainDob}}</div></div>
                  <div class="kv__row"><div class="kv__k">Idade</div><div class="kv__v">{{captainAge}}</div></div>
                  <div class="kv__row"><div class="kv__k">CPF</div><div class="kv__v">{{captainCpf}}</div></div>
                </div>
              </div>

              <div class="card">
                <div class="card__k">Termos</div>
                <div class="kv">
                  <div class="kv__row"><div class="kv__k">Imagem</div><div class="kv__v">{{termsImageRelease}}</div></div>
                  <div class="kv__row"><div class="kv__k">Responsabilidade</div><div class="kv__v">{{termsResponsibility}}</div></div>
                  <div class="kv__row"><div class="kv__k">IP</div><div class="kv__v">{{termsIp}}</div></div>
                </div>
              </div>
            </div>

            <div class="tableWrap">
              <table class="table table--stack">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Nascimento</th>
                    <th>CPF</th>
                    <th>Endereço</th>
                    <th>Papel</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {{#each participants}}
                    <tr>
                      <td data-label="Nome">
                        <input class="input" form="p-{{id}}-update" name="fullName" type="text" value="{{fullName}}" />
                      </td>
                      <td data-label="Nascimento">
                        <input class="input" form="p-{{id}}-update" name="dob" type="date" value="{{dobValue}}" />
                      </td>
                      <td data-label="CPF">
                        <input class="input" form="p-{{id}}-update" name="cpf" type="text" value="{{cpf}}" />
                      </td>
                      <td data-label="Endereço">
                        <input class="input" form="p-{{id}}-update" name="address" type="text" value="{{address}}" />
                      </td>
                      <td data-label="Papel">
                        <select class="input" form="p-{{id}}-update" name="role">
                          <option value="captain" {{#if (eq roleValue "captain")}}selected{{/if}}>Líder</option>
                          <option value="member" {{#if (eq roleValue "member")}}selected{{/if}}>Participante</option>
                        </select>
                      </td>
                      <td class="tableActions" data-label="Ações">
                        <form id="p-{{id}}-update" method="post" action="/admin/inscricoes/gincana/participants/{{id}}/update"></form>
                        <button class="btn btn--primary" type="submit" form="p-{{id}}-update">Salvar</button>
                        <form method="post" action="/admin/inscricoes/gincana/participants/{{id}}/delete" onsubmit="return confirm('Excluir este participante?');">
                          <button class="btn btn--danger" type="submit">Excluir</button>
                        </form>
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>

            <div style="height:12px"></div>
            <form class="form formFilters" method="post" action="/admin/inscricoes/gincana/{{id}}/participants/add">
              <div class="field">
                <label class="label">Adicionar participante</label>
                <input class="input" name="fullName" type="text" placeholder="Nome completo" required />
              </div>
              <div class="field">
                <label class="label">Nascimento</label>
                <input class="input" name="dob" type="date" required />
              </div>
              <div class="field">
                <label class="label">CPF</label>
                <input class="input" name="cpf" type="text" placeholder="Somente números" required />
              </div>
              <div class="field">
                <label class="label">Endereço</label>
                <input class="input" name="address" type="text" placeholder="Rua, nº, bairro..." required />
              </div>
              <div class="field">
                <label class="label">Papel</label>
                <select class="input" name="role">
                  <option value="member">Participante</option>
                  <option value="captain">Líder</option>
                </select>
              </div>
              <div class="actions">
                <button class="btn btn--primary" type="submit">Adicionar</button>
              </div>
            </form>
          </div>
        </div>
      {{/each}}
    </div>
  </main>
</div>

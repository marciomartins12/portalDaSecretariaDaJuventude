<div class="adminShell">
  {{> adminSidebar active="inscricoes"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Inscritos — Corrida</div>
        <div class="adminTop__meta">{{total}} inscrição(ões)</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <a class="btn btn--primary" href="{{exportHref}}">Exportar DOCX</a>
        <a class="btn" href="/admin/inscricoes">Voltar</a>
      </div>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Lista</div>
        </div>
        <div class="panel__body">
          <form class="form" method="get" action="/admin/inscricoes/corrida" style="margin-bottom:10px">
            <div class="field">
              <label class="label" for="q">Filtrar por nome</label>
              <input class="input" id="q" name="q" type="text" value="{{q}}" placeholder="Ex.: Maria Silva" />
            </div>
            <div>
              <button class="btn btn--primary" type="submit">Filtrar</button>
              <a class="btn" href="/admin/inscricoes/corrida">Limpar</a>
            </div>
          </form>
          <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Inscrição</th>
                <th>Data</th>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th>Endereço</th>
                <th>Bairro</th>
                <th>CPF</th>
                <th>Nascimento</th>
                <th>Idade</th>
                <th>Imagem</th>
                <th>Respons.</th>
                <th>IP</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each rows}}
                <tr>
                  <td class="muted">{{id}}</td>
                  <td class="muted">#{{bib}}</td>
                  <td class="muted">{{createdAt}}</td>
                  <td>{{fullName}}</td>
                  <td class="muted">{{email}}</td>
                  <td class="muted">{{phone}}</td>
                  <td class="muted">{{address}}</td>
                  <td class="muted">{{neighborhood}}</td>
                  <td class="muted">{{cpf}}</td>
                  <td class="muted">{{dob}}</td>
                  <td class="muted">{{age}}</td>
                  <td class="muted">{{termsImageRelease}}</td>
                  <td class="muted">{{termsResponsibility}}</td>
                  <td class="muted">{{termsIp}}</td>
                  <td>
                    <form method="post" action="/admin/inscricoes/corrida/{{id}}/delete">
                      <button class="btn btn--danger" type="submit">Excluir</button>
                    </form>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

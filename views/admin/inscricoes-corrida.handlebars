<div class="adminShell">
  {{> adminSidebar active="inscricoes"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Inscritos — Corrida</div>
        <div class="adminTop__meta">{{total}} inscrição(ões)</div>
      </div>
      <a class="btn" href="/admin/inscricoes">Voltar</a>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Lista</div>
        </div>
        <div class="panel__body">
          <table class="table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each rows}}
                <tr>
                  <td>{{fullName}}</td>
                  <td class="muted">{{email}}</td>
                  <td class="muted">{{phone}}</td>
                  <td>
                    <form method="post" action="/admin/inscricoes/corrida/{{id}}/delete">
                      <button class="btn btn--danger" type="submit">Excluir</button>
                    </form>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

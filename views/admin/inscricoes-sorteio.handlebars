<div class="adminShell">
  {{> adminSidebar active="inscricoes"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Inscritos — Sorteio</div>
        <div class="adminTop__meta">{{total}} inscrição(ões)</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <a class="btn btn--primary" href="{{exportHref}}">Exportar CSV</a>
        <a class="btn" href="/admin/inscricoes">Voltar</a>
      </div>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Lista</div>
        </div>
        <div class="panel__body tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Número</th>
                <th>Data</th>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Telefone</th>
                <th>Endereço</th>
                <th>CPF</th>
                <th>CAF</th>
              </tr>
            </thead>
            <tbody>
              {{#each rows}}
                <tr>
                  <td class="muted">{{id}}</td>
                  <td class="muted">#{{ticket}}</td>
                  <td class="muted">{{createdAt}}</td>
                  <td>{{fullName}}</td>
                  <td class="muted">{{email}}</td>
                  <td class="muted">{{phone}}</td>
                  <td class="muted">{{address}}</td>
                  <td class="muted">{{cpf}}</td>
                  <td class="muted">{{caf}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<div class="adminShell">
  {{> adminSidebar active="dashboard"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Dashboard</div>
        <div class="adminTop__meta">{{admin.email}} • {{admin.role}}</div>
      </div>
      <a class="btn" href="/">Site público</a>
    </div>

    <div class="adminPage">
      <div class="gridCards">
        <a class="card cardLink" href="/admin/inscricoes">
          <div class="card__k">🎉 Total de eventos</div>
          <div class="card__v">{{stats.totalEventos}}</div>
        </a>
        <div class="card">
          <div class="card__k">📱 Dispositivos únicos</div>
          <div class="card__v">{{stats.totalDispositivos}}</div>
        </div>
        <a class="card cardLink" href="/admin/inscricoes">
          <div class="card__k">🧾 Total de inscrições</div>
          <div class="card__v">{{stats.totalInscricoes}}</div>
        </a>
        <a class="card cardLink" href="/admin/inscricoes/gincana">
          <div class="card__k">🏆 Gincana</div>
          <div class="card__v">{{stats.totalGincana}}</div>
        </a>
        <a class="card cardLink" href="/admin/inscricoes/corrida">
          <div class="card__k">🏃 Corrida</div>
          <div class="card__v">{{stats.totalCorrida}}</div>
        </a>
        <a class="card cardLink" href="/admin/inscricoes/sorteio">
          <div class="card__k">🐟 Sorteio</div>
          <div class="card__v">{{stats.totalSorteio}}</div>
        </a>
        <a class="card cardLink" href="/admin/inscricoes/jogos">
          <div class="card__k">🎮 Jogos</div>
          <div class="card__v">{{stats.totalJogos}}</div>
        </a>
      </div>

      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Eventos com mais inscrições</div>
        </div>
        <div class="panel__body">
          <table class="table">
            <thead>
              <tr>
                <th>Evento</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {{#each stats.ranking}}
                <tr>
                  <td><a class="tableLink" href="{{href}}">{{emoji}} {{name}}</a></td>
                  <td>{{total}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<div class="adminShell">
  {{> adminSidebar active="admins"}}

  <main class="adminMain">
    <div class="adminTop">
      <div>
        <div class="adminTop__title">Administradores</div>
        <div class="adminTop__meta">Gerenciamento disponível apenas para MASTER</div>
      </div>
      <a class="btn btn--primary" href="/admin/admins/new">Novo</a>
    </div>

    <div class="adminPage">
      <div class="panel">
        <div class="panel__head">
          <div class="panel__title">Lista</div>
        </div>
        <div class="panel__body tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Role</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each rows}}
                <tr>
                  <td>{{name}}</td>
                  <td>{{email}}</td>
                  <td class="muted">{{role}}</td>
                  <td class="muted">{{presenceStatus}}</td>
                  <td class="tableActions">
                    <a class="btn" href="/admin/admins/{{id}}/edit">Editar</a>
                    {{#if (eq ../admin.role 'MASTER')}}
                      {{#if (eq ../admin.id id)}}
                        <span class="btn" aria-disabled="true" title="Você não pode remover a si mesmo">Remover</span>
                      {{else}}
                        {{#if (and (eq role 'MASTER') (eq ../masterCount 1))}}
                          <span class="btn" aria-disabled="true" title="Não é possível remover o último MASTER">Último MASTER</span>
                        {{else}}
                          <form method="post" action="/admin/admins/{{id}}/delete">
                            <button class="btn btn--danger" type="submit">Remover</button>
                          </form>
                        {{/if}}
                      {{/if}}
                    {{else}}
                      <span class="btn" aria-disabled="true" title="Apenas MASTER pode remover">Remover</span>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<section class="hero">
  <div class="container hero__grid">
    <div class="hero__copy">
      <div class="badge">
        <span class="badge__dot"></span>
        Portal oficial • Secretaria da Juventude 
      </div>
      <h1 class="hero__title">
        Secretaria Municipal<span class="brDesktop"></span>
        da<span class="brMobile"></span> <span class="hero__lineB"><span class="textGradient">Juventude</span><span class="brDesktop"></span>de Peri Mirim</span>
      </h1>
      <p class="hero__subtitle">Conectando oportunidades, talentos e o futuro da juventude.</p>

      <div class="hero__actions">
       
        <a class="btn btn--primary" href="#evento">Ver eventos</a>
      </div>
    </div>

    <div class="hero__panel cardNeon neonBorder cardNeon--pulse hero__panel--homeGincana">
      <div class="heroCard">
        <div class="heroCard__top">
          <div>
            <div class="heroCard__eyebrow heroCard__eyebrow--victory">Destaque • Gincana</div>
            <div class="heroCard__title">{{gincana.title}}</div>
            <div class="heroCard__info">{{gincana.dateLabel}} • {{gincana.location}}</div>
          </div>
          <div class="heroCard__trophy heroCard__trophy--sm" aria-hidden="true">
            <span class="heroCard__trophyGlow"></span>
            <span class="heroCard__trophyIcon">🏆</span>
          </div>
        </div>

        <div class="heroCard__meta heroCard__meta--compact">
          <div class="metaPill metaPill--victory">
            <span class="i" aria-hidden="true">🏆</span>
            <span class="metaPill__text">{{#if podium.first}}Campeã: {{podium.first.teamName}}{{else}}Campeã em breve{{/if}}</span>
          </div>
          <div class="metaPill">
            <span class="i" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7 3v3M17 3v3M4.5 8.5h15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                <path d="M6 6h12a2.5 2.5 0 0 1 2.5 2.5v10A2.5 2.5 0 0 1 18 21H6a2.5 2.5 0 0 1-2.5-2.5v-10A2.5 2.5 0 0 1 6 6Z" stroke="currentColor" stroke-width="1.6"/>
              </svg>
            </span>
            {{gincana.dateLabel}}
          </div>
          <div class="metaPill">
            <span class="i" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 21s7-4.4 7-11a7 7 0 1 0-14 0c0 6.6 7 11 7 11Z" stroke="currentColor" stroke-width="1.6"/>
                <path d="M12 10.8a2.2 2.2 0 1 0 0-4.4 2.2 2.2 0 0 0 0 4.4Z" fill="currentColor" opacity=".85"/>
              </svg>
            </span>
            <span class="metaPill__text">{{gincana.location}}</span>
          </div>
        </div>

        <div class="heroCard__actions">
          <a class="btn btn--primary btn--wide" href="/gincana">Acompanhar gincana</a>
          <a class="btn btn--ghost btn--wide" href="/editais/">Ver edital</a>
        </div>
      </div>
    </div>
  </div>
</section>


<section class="section">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title">Secretaria da Juventude</h2>
      <p class="section__desc">O que fazemos para fortalecer oportunidades e participação da juventude de Peri Mirim.</p>
    </div>

    <div class="aboutPanel cardNeon neonBorder cardNeon--pulse reveal">
      <div class="aboutMain">
        <div class="aboutMain__eyebrow">Secretaria Municipal da Juventude</div>
        <div class="aboutMain__title">O que fazemos</div>
        <div class="aboutMain__desc">
          Apoiamos iniciativas, ações e projetos que aproximam a juventude de oportunidades e fortalecem o protagonismo no
          município.
        </div>

        <div class="aboutHighlights">
          <div class="aboutHighlight">
            <div class="aboutHighlight__k">Formação</div>
            <div class="aboutHighlight__v">Oficinas, orientação e desenvolvimento</div>
          </div>
          <div class="aboutHighlight">
            <div class="aboutHighlight__k">Cultura &amp; Esporte</div>
            <div class="aboutHighlight__v">Incentivo a eventos, talentos e atividades</div>
          </div>
          <div class="aboutHighlight">
            <div class="aboutHighlight__k">Participação</div>
            <div class="aboutHighlight__v">Educação, cidadania e ações comunitárias</div>
          </div>
        </div>
        <div style="margin-top:12px">
          <a class="btn btn--soft" href="/peri-mirim">Conheça Peri Mirim (MA)</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section--highlight" id="evento">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title">Eventos</h2>
      <p class="section__desc">Gincana Celebra Peri Mirim e Feirinha do Povo.</p>
    </div>

    <div class="eventsGrid">
      <article class="eventCard eventCard--main glass reveal" id="evento-gincana">
        <div class="eventRow">
          <div class="eventRow__icon card__icon" aria-hidden="true" data-icon="spark"></div>
          <div class="eventRow__main">
            <div class="eventCard__badge">Gincana</div>
            <h3 class="eventCard__title">{{gincana.title}}</h3>
            <p class="eventCard__desc">{{gincana.subtitle}}</p>
            <p class="eventCard__winner">{{#if podium.first}}Equipe campeã: <strong>{{podium.first.teamName}}</strong>{{else}}Equipe campeã: em breve{{/if}}</p>
            <div class="eventCard__meta">
              <div class="metaPill">{{gincana.dateLabel}}</div>
              <div class="metaPill">{{gincana.location}}</div>
              <div class="metaPill metaPill--accent">{{gincana.prize}}</div>
            </div>
          </div>
          <div class="eventRow__actions">
            <a class="btn btn--primary" href="/gincana">Acompanhar gincana</a>
            <a class="btn btn--ghost" href="/editais">Ver edital</a>
          </div>
        </div>
      </article>

      <article class="eventCard glass reveal" id="evento-feirinha">
        <div class="eventRow">
          <div class="eventRow__icon card__icon" aria-hidden="true" data-icon="users"></div>
          <div class="eventRow__main">
            <div class="eventCard__badge">Feirinha do Povo</div>
            <h3 class="eventCard__title">{{feirinha.title}}</h3>
            <p class="eventCard__desc">{{feirinha.subtitle}}</p>
            <div class="eventCard__meta">
              <div class="metaPill">{{feirinha.dateLabel}}</div>
              <div class="metaPill">{{feirinha.location}}</div>
            </div>
            <p class="eventCard__desc">Inclui sorteio de alevinos para piscicultores.</p>
          </div>
          <div class="eventRow__actions">
            <a class="btn btn--primary" href="/eventos#evento-feirinha">Ver detalhes</a>
            <a class="btn btn--ghost" href="/editais">Ver editais</a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section__head">
      <h2 class="section__title">Notícias da Juventude</h2>
      <p class="section__desc">Informações, projetos e novidades para acompanhar de perto.</p>
    </div>

    <div class="grid3">
      {{#each news}}
        <article class="newsCard glass reveal">
          <div class="newsCard__media">
            <img src="{{image}}" alt="" loading="lazy" />
          </div>
          <div class="newsCard__body">
            <div class="newsCard__meta">
              <span class="chip">Juventude</span>
              <span class="newsCard__date">{{date}}</span>
            </div>
            <h3 class="newsCard__title">{{title}}</h3>
            <p class="newsCard__desc">{{excerpt}}</p>
            <a class="link" href="/noticias">Ler mais</a>
          </div>
        </article>
      {{/each}}
    </div>
  </div>
</section>

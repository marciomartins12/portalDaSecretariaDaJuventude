<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{title}}</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/png" href="/public/assets/iconePNG.png?v={{assetVersion}}" />
    <link rel="apple-touch-icon" href="/public/assets/iconePNG.png?v={{assetVersion}}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    {{#if showPublicChrome}}
      <link rel="stylesheet" href="/public/css/styles.css?v={{assetVersion}}" />
    {{/if}}
    <link rel="stylesheet" href="/public/css/admin.css?v={{assetVersion}}" />
  </head>
  <body>
    {{#if showPublicChrome}}
      {{> navbar}}
      <main class="main">
        {{{body}}}
      </main>
      {{> footer}}
      <script src="/public/js/main.js?v={{assetVersion}}" defer></script>
    {{else}}
      {{{body}}}
      <script src="/socket.io/socket.io.js"></script>
      <script>
        (function () {
          try {
            if (window.io) {
              window.io({ withCredentials: true });
            }
          } catch {}
        })();
      </script>
    {{/if}}
  </body>
</html>

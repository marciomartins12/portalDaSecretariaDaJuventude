<section class="pageHero">
  <div class="container pageHero__grid">
    <div>
      {{> pageCrumb current="Inscrições"}}
      <div class="badge">
        <span class="badge__dot"></span>
        Participe dos eventos
      </div>
      <h1 class="pageHero__title">Inscrições</h1>
      <p class="pageHero__subtitle">Escolha o evento e faça sua inscrição.</p>
    </div>

    <div class="pageHero__card glass">
      <div class="note">
        <span class="note__dot" aria-hidden="true"></span>
        Formulários organizados por evento. Preencha com atenção.
      </div>
      <div class="pageHero__actions">
        <a class="btn btn--soft" href="/editais">Ver editais</a>
        <a class="btn btn--ghost" href="/">Voltar ao início</a>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid2">
      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="spark"></div>
        <h2 class="card__title">Inscrição da Gincana</h2>
        <p class="card__desc">{{gincana.title}} • {{gincana.dateLabel}}</p>
        <div class="cardChips">
          <span class="chip">Equipe</span>
          <span class="chip">Capitão 17+</span>
          <span class="chip">Participante 15+</span>
        </div>
        <div class="cardActions">
          <a class="btn btn--primary" href="/gincana">Acompanhar gincana</a>
          <a class="btn btn--ghost" href="/editais">Ver edital</a>
        </div>
      </article>

      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="target"></div>
        <h2 class="card__title">Inscrição — Jogos Variados</h2>
        <p class="card__desc">Escolha seus esportes e participe</p>
        <div class="cardChips">
          <span class="chip">Dominó</span>
          <span class="chip">Sinuca</span>
          <span class="chip">Travinho</span>
          <span class="chip">Videogame (Bomba Patch)</span>
          <span class="chip">Dama</span>
        </div>
        <div class="cardActions">
          <a class="btn btn--primary" href="/inscricoes/jogos">Fazer inscrição</a>
        </div>
      </article>

      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="target"></div>
        <h2 class="card__title">Sorteio para Piscicultores</h2>
        <p class="card__desc">Feirinha do Povo • 30 de março • 10 mil alevinos</p>
        <div class="cardChips">
          <span class="chip">Pequeno empreendedor</span>
          <span class="chip">Número por inscrição</span>
        </div>
        <div class="cardActions">
          <a class="btn btn--primary" href="/inscricoes/piscicultores">Fazer inscrição</a>
          <a class="btn btn--ghost" href="/inscricoes">Voltar</a>
        </div>
      </article>

      <article class="card glass reveal">
        <div class="card__icon" aria-hidden="true" data-icon="bolt"></div>
        <h2 class="card__title">Inscrição da Corrida</h2>
        <p class="card__desc">Corrida Celebra Peri Mirim • Dia 28 • 6h</p>
        <div class="cardChips">
          <span class="chip">15+</span>
          <span class="chip">Praça Secundino → Matriz</span>
        </div>
        <div class="cardActions">
          <a class="btn btn--primary" href="/inscricoes/corrida">Fazer inscrição</a>
          <a class="btn btn--ghost" href="/editais">Ver editais</a>
        </div>
      </article>
    </div>
  </div>
</section>
